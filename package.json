{
  "name": "@seongwon030/velog-mcp-claude",
  "version": "0.16.0",
  "description": "MCP server for Velog - draft, publish, and manage posts via Claude",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "velog",
    "blog",
    "claude",
    "ai"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "velog-mcp-claude": "dist/index.js",
    "velog-mcp-setup": "dist/setup.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "setup": "node dist/setup.js",
    "health": "node scripts/health-check.mjs",
    "test": "vitest run",
    "lint": "biome check .",
    "lint:fix": "biome check --write --unsafe .",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "nanoid": "^5.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seongwon030/velog_mcp.git"
